{
	"name": "apfel-sequence-monorepo",
	"private": true,
	"author": "Mehmed Kurtic",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mkurtic/apfel-sequence.git"
	},
	"bugs": {
		"url": "https://github.com/mkurtic/apfel-sequence/issues"
	},
	"homepage": "https://github.com/mkurtic/apfel-sequence#readme",
	"keywords": [
		"apfel-sequence",
		"canvas",
		"animation",
		"scroll-trigger",
		"image-sequence",
		"performance"
	],
	"workspaces": [
		"packages/*",
		"playgrounds/astro"
	],
	"scripts": {
		"build:core": "npm run build -w @apfel-sequence/core",
		"build:vanilla": "npm exec -- vite build --config packages/vanilla/vite.config.ts",
		"build:react": "vite build --config packages/react/vite.config.ts",
		"build:vue": "npm exec -- vite build --config packages/vue/vite.config.ts",
		"build:all": "npm run build:core && npm run build:vanilla && npm run build:react && npm run build:vue",
		"dev:core": "npm run dev -w @apfel-sequence/core",
		"dev:vanilla": "npm run dev -w @apfel-sequence/vanilla",
		"dev:react": "npm run dev -w @apfel-sequence/react",
		"dev:vue": "npm run dev -w @apfel-sequence/vue",
		"dev": "concurrently \"npm run dev:core\" \"npm run dev:vanilla\" \"npm run dev:react\" \"npm run dev:vue\"",
		"test": "vitest run --config packages/core/vitest.config.mts --reporter=verbose --pool=forks",
		"test:watch": "vitest --config packages/core/vitest.config.mts --watch",
		"release": "npm run build:all && changeset publish",
		"format": "prettier --write \"**/*.{js,ts,tsx,vue,mts,cjs,mjs,json,md,css,html}\"",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@eslint/js": "^10.0.1",
		"@vitejs/plugin-react": "^4.0.0",
		"@vitejs/plugin-vue": "^5.0.0",
		"concurrently": "^9.2.1",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^17.0.5",
		"prettier-plugin-astro": "^0.14.1",
		"tsup": "^7.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.59.4",
		"vite": "^5.0.0",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.0.16"
	}
}

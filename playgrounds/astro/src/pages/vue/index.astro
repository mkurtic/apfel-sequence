---
import ApfelSequence from '@apfel-sequence/vue';
import Layout from '../../layouts/Layout.astro';
import { heroAssets, heroLoadingConfig, section2Assets, section2LoadingConfig, section2ScrollConfig, commonDrawMode } from "./../../utils/sequenceData"
---
<Layout>
	<section id="hero">
		<ApfelSequence 
			client:only="vue" 
			assetsConfig={heroAssets}
			loadingConfig={heroLoadingConfig}
			alt={"My hero alt text"} 
			drawMode={commonDrawMode}
		/>
	</section>
	<section id="section-2">
		<ApfelSequence 
			client:only="vue" 
			assetsConfig={section2Assets}
			loadingConfig={section2LoadingConfig}
			scrollConfig={section2ScrollConfig}
			alt={"Section alt text"} 
			drawMode={commonDrawMode}
		/>
	</section>
	<section></section>
</Layout>


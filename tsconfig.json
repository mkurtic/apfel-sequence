{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"jsx": "preserve",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"useUnknownInCatchVariables": true,
		"noImplicitOverride": true,
		"verbatimModuleSyntax": true,
		"allowJs": true,
		"declaration": true,
		"declarationDir": "dist",
		"emitDeclarationOnly": true,
		"baseUrl": ".",
		"paths": {
			"@apfel-sequence/core": ["packages/core/src"],
			"@apfel-sequence/vanilla": ["packages/vanilla/src"],
			"@apfel-sequence/react": ["packages/react/src"],
			"@apfel-sequence/vue": ["packages/vue/src"],
			"~/*": ["src/*"],
			"test/*": ["test/*"]
		},
		"typeRoots": ["node_modules/@types", "packages/types"]
	},
	"include": [
		"packages/core/src",
		"packages/vanilla/src",
		"packages/react/src",
		"packages/vue/src",
		"playgrounds/**/*",
		"src",
		"test",
		"src/types"
	],
	"exclude": ["dist", "node_modules"]
}
